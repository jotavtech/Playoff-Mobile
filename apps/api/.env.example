# Atlas Playoff API — environment template.
# Copy to apps/api/.env and fill in real values. NEVER commit the real .env.

# Runtime
NODE_ENV=
PORT=3333
APP_BASE_URL=

# Database (PostgreSQL)
DATABASE_URL=

# Spotify Web API (OAuth PKCE + client-credentials)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=30d

# Mobile deep-link redirect
MOBILE_REDIRECT_URI=
