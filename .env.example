# Copy to apps/mobile/.env (or root .env — Expo loads EXPO_PUBLIC_* from app dir)

EXPO_PUBLIC_APP_ENV=development

# Supabase — project syiuzmnsqxhiilikhwmw
# Dashboard → Settings → API → anon public key
EXPO_PUBLIC_SUPABASE_URL=https://syiuzmnsqxhiilikhwmw.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Migrations / CLI only (nunca EXPO_PUBLIC_) — use Session Pooler se IPv4
# Dashboard → Connect → Session pooler (port 5432)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# Direct (IPv6): postgresql://postgres:[YOUR-PASSWORD]@db.syiuzmnsqxhiilikhwmw.supabase.co:5432/postgres

# Spotify Developer Dashboard — https://developer.spotify.com/dashboard
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=
EXPO_PUBLIC_SPOTIFY_REDIRECT_URI=playoff://auth/callback

# Sentry — optional Phase 6
EXPO_PUBLIC_SENTRY_DSN=

# Server-only (NEVER prefix with EXPO_PUBLIC_) — use Supabase Edge Functions
# SPOTIFY_CLIENT_SECRET=
# SUPABASE_SERVICE_ROLE_KEY=
