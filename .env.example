# ─────────────────────────────────────────────────────────────
# Atlas Playoff Mobile — environment template
# Copy to:  apps/api/.env   and   apps/mobile/.env
# NEVER commit real values. NEVER prefix secrets with EXPO_PUBLIC_.
# ─────────────────────────────────────────────────────────────

# ===== BACKEND (apps/api/.env) — server-only secrets =====
NODE_ENV=development
PORT=3333
APP_BASE_URL=http://localhost:3333

# Database (PostgreSQL — Neon / Supabase / local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/atlas_playoff?schema=public"

# Spotify (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=playoff://auth/callback

# OpenAI (https://platform.openai.com/api-keys) — backend ONLY
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# Mobile deep-link the backend redirects back to after OAuth
MOBILE_REDIRECT_URI=playoff://auth/callback

# ===== MOBILE (apps/mobile/.env) — PUBLIC values only =====
# The mobile app talks ONLY to the Atlas backend. No OpenAI key, no Spotify secret here.
EXPO_PUBLIC_API_URL=http://localhost:3333
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=
EXPO_PUBLIC_SPOTIFY_REDIRECT_URI=playoff://auth/callback
EXPO_PUBLIC_APP_ENV=development
